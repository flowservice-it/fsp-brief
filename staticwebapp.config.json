{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/14d67554-c862-4d9a-bb7b-0e290d5236dc/v2.0",
          "clientIdSettingName": "AAD_CLIENT_ID",
          "clientSecretSettingName": "AAD_CLIENT_SECRET"
        }
      }
    },
    "rolesSource": "/api/getRoles"
  },
  "routes": [
    {
      "route": "/api/getRoles",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/admin.html",
      "allowedRoles": ["briefAdmin"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/admin.html",
      "statusCode": 302
    }
  }
}
